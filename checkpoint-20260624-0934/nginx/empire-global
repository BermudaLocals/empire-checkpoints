# KUSH Brain / Agent Zero
server {
    listen 80;
    server_name agent.nvme.live kush.nvme.live;
    location / { proxy_pass http://localhost:5080; proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host; }
}

# nvme.live (rebuilding — serve maintenance page)
server {
    listen 80;
    server_name nvme.live www.nvme.live;
    location / { proxy_pass http://localhost:3005;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr; }
}

